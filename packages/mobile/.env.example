# EXPO_PUBLIC_* são expostos no cliente (mobile bundle).
# Não coloque segredos aqui — só endpoints e flags não-sensíveis.

# URL base do backend (use seu ngrok/Cloudflare Tunnel/prod URL)
EXPO_PUBLIC_API_BASE=https://api.kratos-suno.felipemoulin.com

# Shared secret do Stage 1 (X-Kratos-Key). NÃO é 100% seguro em bundle mobile
# — ofusca contra acesso casual, mas um usuário determinado consegue extrair
# do .ipa/.apk. Para Stage 3 migre para Clerk.
EXPO_PUBLIC_SHARED_SECRET=replace-with-16-plus-char-secret-from-openssl-rand-hex-24
