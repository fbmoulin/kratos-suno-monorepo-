# Root .env for docker-compose.dev.yml
# Copy to .env and fill real values. .env is gitignored.

# REQUIRED
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTIONAL — Stage 1 hardening (W1-A)
# Empty SHARED_SECRET_KEY = auth disabled (fine for localhost dev)
SHARED_SECRET_KEY=
RATE_LIMIT_PER_HOUR=100
DAILY_BUDGET_USD=2.0
LOG_FORMAT=console

# OPTIONAL — Spotify (W1-B)
# Leave empty to disable Spotify integration
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback
SPOTIFY_MOBILE_REDIRECT_URI=
# Generate JWT secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
