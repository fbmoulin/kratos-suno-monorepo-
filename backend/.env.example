# ===========================================================================
# Kratos Suno Prompt - Environment Variables
# ===========================================================================
# Copie este arquivo para `.env` e preencha os valores reais.

# ----- App -----
DEBUG=true
FRONTEND_ORIGIN=http://localhost:5173

# ----- Anthropic (OBRIGATÓRIO) -----
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Modelos por papel (pode deixar os defaults)
DNA_EXTRACTOR_MODEL=claude-haiku-4-5-20251001
AUDIO_DNA_MODEL=claude-sonnet-4-6
VALIDATOR_MODEL=claude-haiku-4-5-20251001

# ----- Prompt versioning -----
ACTIVE_PROMPT_VERSION=v1_baseline

# ----- Database (Fase 3) -----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kratos_suno

# ----- Upload limits -----
MAX_AUDIO_UPLOAD_MB=25

# ----- Spotify OAuth (opcional — app funciona sem Spotify) -----
# Crie um app em https://developer.spotify.com/dashboard
# Redirect URI no Spotify Dashboard deve bater com SPOTIFY_REDIRECT_URI abaixo
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/spotify/callback
# W1-B: mobile redirect — must also be registered in the Spotify app dashboard
SPOTIFY_MOBILE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/spotify/mobile-callback
SPOTIFY_MOBILE_SCHEME=kratossuno://spotify-connected

# ----- DNA Cache -----
DNA_CACHE_ENABLED=true
DNA_CACHE_TTL_DAYS=30

# ----- Sessions -----
SESSION_TTL_SECONDS=604800  # 7 dias

# ----- JWT (W1-B) — bearer tokens for mobile -----
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-48-hex-in-prod
JWT_TTL_SECONDS=604800
